#define led 13
#define button_1 12
#define button_2 11
boolean value_1=0;
boolean value_2=0;
void setup()
{
  pinMode(led, OUTPUT);
  pinMode(button_1, INPUT);
  pinMode(button_2, INPUT);
  digitalWrite(led, LOW);
  
  
}

void loop()
{
  value_1 =digitalRead(button_1);
  value_2 =digitalRead(button_2);
  if (value_1&&value_2)
    digitalWrite(led, HIGH);
  else
    digitalWrite(led, LOW);
}